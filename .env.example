# ============================================================
# HireAI GenAI — Environment Config
# LLM backend: Ollama (local). No API keys required.
# ============================================================

# --- Ollama (local inference — no API key) ---
# Install: https://ollama.com/download
# Pull model: ollama pull gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Model selection (Ollama model tags) ---
# Change to gemma3:12b or gemma3:27b for higher accuracy (needs more RAM)
PARSER_MODEL=gemma3:4b
COPILOT_MODEL=gemma3:4b
EXPLAIN_MODEL=gemma3:4b

# --- Infra ---
REDIS_URL=redis://localhost:6379/0
WEB_BACKEND_URL=http://localhost:8000/api

# --- Service ---
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
LOG_LEVEL=INFO

# --- Cost guardrails (local models cost $0, caps kept for structure) ---
DAILY_SPEND_CAP_USD=10.0
PROJECT_SPEND_CAP_USD=200.0
COST_LOG_PATH=data/cost_log.jsonl

# --- Cache ---
DEFAULT_CACHE_TTL_SECONDS=3600

# --- Slack (nightly cost summary + regression alerts) ---
# Leave empty for offline dev — scripts/nightly.py no-ops and logs instead.
SLACK_WEBHOOK_URL=
