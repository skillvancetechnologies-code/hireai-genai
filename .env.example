# --- LLM ---
OPENAI_API_KEY=sk-replace-me
GEMINI_API_KEY=

# --- Models ---
PARSER_MODEL=gpt-4o-mini
COPILOT_MODEL=gpt-4o-mini
EXPLAIN_MODEL=gpt-4o

# --- Infra ---
# Point at hireai-web's docker-compose Redis (the one /readyz checks)
REDIS_URL=redis://localhost:6379/0
WEB_BACKEND_URL=http://localhost:8000/api

# --- Service ---
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
LOG_LEVEL=INFO

# --- Cost guardrails ---
DAILY_SPEND_CAP_USD=10.0
PROJECT_SPEND_CAP_USD=200.0
COST_LOG_PATH=data/cost_log.jsonl

# --- Cache ---
DEFAULT_CACHE_TTL_SECONDS=3600

# --- Slack (nightly cost summary + regression alerts) ---
# Leave empty for offline dev — scripts/nightly.py no-ops and logs instead.
SLACK_WEBHOOK_URL=
